<Window x:Class="ClipFrame.UI.MirrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipFrame View"
        Icon="pack://application:,,,/Assets/appicon.ico"
        Width="640" Height="360"
        MinWidth="200" MinHeight="140"
        Background="Black"
        UseLayoutRounding="True">
    <Grid>
        <Image x:Name="MirrorImage"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="LowQuality"
               SnapsToDevicePixels="True" />

        <!-- Self-reflection warning (spec §5) -->
        <Border x:Name="OverlapWarning"
                Visibility="Collapsed"
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Background="#CCB00020" Padding="10,6">
            <TextBlock Foreground="White" FontSize="12" TextWrapping="Wrap"
                       Text="⚠ ミラーウィンドウが共有領域に重なっています(合わせ鏡)。領域の外へ移動してください。" />
        </Border>

        <!-- Shown while paused -->
        <TextBlock x:Name="PausedLabel"
                   Visibility="Collapsed"
                   Text="⏸ 一時停止中"
                   Foreground="#CCFFFFFF" FontSize="16"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,12" />
    </Grid>
</Window>
