<Window x:Class="ClipFrame.UI.CoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipFrame Cover"
        Icon="pack://application:,,,/Assets/appicon.ico"
        Width="640" Height="360"
        MinWidth="200" MinHeight="140"
        ShowInTaskbar="False"
        Background="#FF32373C"
        UseLayoutRounding="True">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="ClipFrame Cover"
                       Foreground="#66FFFFFF" FontSize="20"
                       HorizontalAlignment="Center" />
            <TextBlock Text="ミラーの映り込みを隠すカバーです(このまま共有映像に映ります)"
                       Foreground="#44FFFFFF" FontSize="12" Margin="0,6,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" />
            <Button Content="カバー消去"
                    Margin="0,16,0,0" Padding="14,6"
                    HorizontalAlignment="Center"
                    Click="OnHideClick" />
        </StackPanel>
    </Grid>
</Window>
