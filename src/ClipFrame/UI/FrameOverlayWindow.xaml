<Window x:Class="ClipFrame.UI.FrameOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipFrame Frame"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="#FF2FA8FF"
        Width="400" Height="300">

    <!-- The window Background paints the outer frame ring. The interior is
         physically cut away with SetWindowRgn so underlying apps stay clickable.
         Only the tag (positioned on the Canvas) draws over the region top edge. -->
    <Canvas x:Name="RootCanvas">
        <Border x:Name="TagBar"
                Height="26"
                CornerRadius="0,0,6,6"
                Background="#FF1E6FB0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Slide grip (drag to slide the tag along the top edge) -->
                <Border x:Name="Grip" Grid.Column="0"
                        Width="18" Background="#33FFFFFF"
                        Cursor="SizeWE" ToolTip="ドラッグでタグを左右にスライド">
                    <TextBlock Text="⋮⋮" Foreground="White" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="Bold" />
                </Border>

                <TextBlock Grid.Column="1" x:Name="TitleText"
                           Text="ClipFrame"
                           Foreground="White" FontSize="12" FontWeight="SemiBold"
                           Margin="8,0,8,0"
                           VerticalAlignment="Center" />

                <Border Grid.Column="2" Background="#55000000"
                        CornerRadius="3" Margin="4,3,6,3" Padding="6,1">
                    <TextBlock x:Name="ResBadge" Text="0 × 0"
                               Foreground="White" FontSize="11"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Canvas>
</Window>
